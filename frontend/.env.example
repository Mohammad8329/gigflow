# ==========================================
# FRONTEND ENVIRONMENT VARIABLES (.env)
# Location: /frontend/.env
# ==========================================

# API Connection
# Note: The frontend codebase is engineered with a local fallback 
# (import.meta.env.VITE_API_URL || 'http://localhost:5000/api').
# Therefore, creating a local .env file is OPTIONAL for local development.

# To override the default local API port, uncomment the line below:
# VITE_API_URL=http://localhost:5000/api

# For Production (e.g., Vercel), set this variable in your hosting dashboard:
# VITE_API_URL=https://gigflow-g88v.onrender.com/api